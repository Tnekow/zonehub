{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "./",
    "outDir": "./dist-electron",
    "types": ["node"],
    "strict": false,
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": ["main/**/*.ts", "preload/**/*.ts", "services/**/*.ts"]
}

